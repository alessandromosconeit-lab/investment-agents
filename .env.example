# Copia questo file come .env e compila i valori
# MAI committare il file .env su Git — è già in .gitignore

# Financial Modeling Prep — https://financialmodelingprep.com/developer/docs
FMP_API_KEY=la_tua_chiave_fmp

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=la_tua_chiave_anthropic

# Gmail — usa una App Password, NON la password del tuo account Google
# Come crearla: https://myaccount.google.com/apppasswords
# (Richiede 2FA attiva sull'account Gmail)
GMAIL_USER=tuo_account@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
